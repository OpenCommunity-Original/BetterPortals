{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Run Full Stack (Server + Client)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Kill Java",
                "Cleanup Test Data",
                "Build All Plugins",
                "Start All Instances"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Kill Java",
            "type": "shell",
            "command": "if (Get-Process java -ErrorAction SilentlyContinue) { Get-Process java | Stop-Process -Force }",
            "windows": {
                "command": "if (Get-Process java -ErrorAction SilentlyContinue) { Get-Process java | Stop-Process -Force }"
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "Start All Instances",
            "dependsOn": [
                "Start Paper Server",
                "Start Minecraft Client"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Start Paper Server",
            "type": "shell",
            "command": ".\\gradlew :test-server:runServer",
            "isBackground": true,
            "presentation": {
                "group": "bp-stack",
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Start Folia Server",
            "type": "shell",
            "command": ".\\gradlew :test-server:runFolia",
            "isBackground": true,
            "presentation": {
                "group": "bp-stack",
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Start Minecraft Client",
            "type": "shell",
            "command": ".\\gradlew :test-client:runClient",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Start Minecraft Client Low",
            "type": "shell",
            "command": ".\\gradlew :test-client:runClientLow",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Start Folia All Instances",
            "dependsOn": [
                "Start Folia Server",
                "Start Minecraft Client Low"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "🚀 Run Folia Stack (Folia + Client)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Kill Java",
                "Cleanup Test Data",
                "Build All Plugins",
                "Start Folia All Instances"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Cleanup Test Data",
            "type": "shell",
            "command": ".\\gradlew cleanTest",
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "Build All Plugins",
            "type": "shell",
            "command": ".\\gradlew buildAll",
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "Gradle Build",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew.bat",
            "args": [
                "build"
            ],
            "group": "build",
            "problemMatcher": [],
            "windows": {
                "command": "${workspaceFolder}/gradlew.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/gradlew"
            },
            "osx": {
                "command": "${workspaceFolder}/gradlew"
            }
        },
        {
            "label": "Gradle ShadowJar",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew.bat",
            "args": [
                "shadowJar"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "windows": {
                "command": "${workspaceFolder}/gradlew.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/gradlew"
            },
            "osx": {
                "command": "${workspaceFolder}/gradlew"
            }
        },
        {
            "label": "Gradle Test",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew.bat",
            "args": [
                "test"
            ],
            "group": "test",
            "problemMatcher": [],
            "windows": {
                "command": "${workspaceFolder}/gradlew.bat"
            },
            "linux": {
                "command": "${workspaceFolder}/gradlew"
            },
            "osx": {
                "command": "${workspaceFolder}/gradlew"
            }
        }
    ]
}
